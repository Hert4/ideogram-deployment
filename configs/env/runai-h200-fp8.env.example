# Copy to .env, fill secrets, then `set -a; source .env; set +a`.
#
# First Run:ai ask:
# - H200
# - 48GiB GPU memory
# - 8-16 CPU cores
# - 64-96GiB RAM
# - 200-300GiB persistent Hugging Face cache

HF_TOKEN=
HF_HOME=/cache/huggingface
HF_XET_HIGH_PERFORMANCE=1

IDEOGRAM_API_KEY=
HIVE_TEXT_MODERATION_KEY=
HIVE_VISUAL_MODERATION_KEY=

CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

IDEOGRAM_DEVICE=cuda
IDEOGRAM_QUANTIZATION=fp8
IDEOGRAM_HEIGHT=1024
IDEOGRAM_WIDTH=1024
IDEOGRAM_PRESET=V4_TURBO_12
IDEOGRAM_SEED=0
IDEOGRAM_OUTPUT=/outputs/h200_fp8_smoke.png
