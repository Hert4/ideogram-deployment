# Copy to .env, fill secrets, then `set -a; source .env; set +a`.

# Required after accepting the Hugging Face model gate.
HF_TOKEN=
HF_HOME="$HOME/.cache/huggingface"

# Optional. Only needed if you use plain prompts and magic prompt expansion.
IDEOGRAM_API_KEY=

# Optional production safety keys.
HIVE_TEXT_MODERATION_KEY=
HIVE_VISUAL_MODERATION_KEY=

# Apple Silicon smoke settings.
PYTORCH_ENABLE_MPS_FALLBACK=1
IDEOGRAM_DEVICE=mps
IDEOGRAM_QUANTIZATION=int8-mps
IDEOGRAM_HEIGHT=512
IDEOGRAM_WIDTH=512
IDEOGRAM_PRESET=V4_TURBO_12
IDEOGRAM_SEED=0
IDEOGRAM_OUTPUT=int8_out.png
