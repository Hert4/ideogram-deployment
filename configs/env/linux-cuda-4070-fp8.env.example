# Copy to .env, fill secrets, then `set -a; source .env; set +a`.
#
# RTX 4070/4070 Ti class cards are useful for FP8 CUDA smoke tests, but the
# stock Ideogram4 FP8 loader is likely VRAM-limited. Start at 512x512.

HF_TOKEN=
HF_HOME="$HOME/.cache/huggingface"
IDEOGRAM_API_KEY=
HIVE_TEXT_MODERATION_KEY=
HIVE_VISUAL_MODERATION_KEY=

CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

IDEOGRAM_DEVICE=cuda
IDEOGRAM_QUANTIZATION=fp8
IDEOGRAM_HEIGHT=512
IDEOGRAM_WIDTH=512
IDEOGRAM_PRESET=V4_TURBO_12
IDEOGRAM_SEED=0
IDEOGRAM_OUTPUT=outputs/4070_fp8_smoke.png
